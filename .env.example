NODE_ENV=development

# DATABASE_URL: role privilegiada, usada só por drizzle-kit para rodar migrations
# (precisa poder criar tabelas/roles/policies).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_commerce

# APP_DATABASE_URL: role não-superusuário (app_role, criada pela migration
# 0002_app_role_bootstrap.sql) usada pela aplicação em runtime. Isto é o que
# faz o RLS de multi-tenancy valer de verdade — superusuários sempre ignoram
# RLS no Postgres, então a app NUNCA deve consultar dados de negócio usando
# DATABASE_URL. Senha local de exemplo (troque em qualquer ambiente real):
APP_DATABASE_URL=postgres://app_role:app_role_local_dev_only@localhost:5432/ai_commerce

# CREDENTIAL_ENCRYPTION_KEY: Chave de 32 bytes (256 bits) codificada em base64.
# Usada para cifrar credenciais reais de ERPs e Marketplaces (AES-256-GCM).
# Gere uma chave segura no terminal usando o comando: openssl rand -base64 32
# CREDENTIAL_ENCRYPTION_KEY=sua_chave_base64_gerada_aqui

# AUTH_SECRET: usada pelo Auth.js (NextAuth v5) para assinar/criptografar o JWT
# de sessão. Sem isso configurado em produção, login falha. Gere com:
# openssl rand -base64 32 (ou PowerShell: ver HISTORICO_PROJETO.md)
# AUTH_SECRET=sua_chave_base64_gerada_aqui

# REDIS_HOST / REDIS_PORT: usadas pelo apps/worker (BullMQ) para a fila de jobs.
# Em dev local, sobem via docker-compose (serviço "redis"). Em produção, apontar
# para uma instância Redis gerenciada (Upstash, Redis Cloud, etc.) — ainda não
# configurado.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ADAPTER_MODE: 'mock' (default) ou 'real'. Só ligue 'real' com as credenciais Bling
# abaixo configuradas e em ambiente sandbox. Em produção, mantenha 'mock' até o
# handshake OAuth estar validado.
# ADAPTER_MODE=mock

# BLING_CLIENT_ID / BLING_CLIENT_SECRET: credenciais do APP Bling (nível plataforma),
# obtidas no painel de desenvolvedor do Bling em modo SANDBOX. Usadas pelo adapter real
# (packages/integrations/src/real/bling.adapter.ts) no handshake OAuth2. Opcionais até
# ADAPTER_MODE=real. NUNCA commitar valores reais.
# BLING_CLIENT_ID=
# BLING_CLIENT_SECRET=
# BLING_REDIRECT_URI: URL de callback registrada no app Bling (necessária no primeiro
# handshake com authorization_code).
# BLING_REDIRECT_URI=
