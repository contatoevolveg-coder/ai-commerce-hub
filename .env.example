NODE_ENV=development

# DATABASE_URL: role privilegiada, usada só por drizzle-kit para rodar migrations
# (precisa poder criar tabelas/roles/policies).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_commerce

# APP_DATABASE_URL: role não-superusuário (app_role, criada pela migration
# 0002_app_role_bootstrap.sql) usada pela aplicação em runtime. Isto é o que
# faz o RLS de multi-tenancy valer de verdade — superusuários sempre ignoram
# RLS no Postgres, então a app NUNCA deve consultar dados de negócio usando
# DATABASE_URL. Senha local de exemplo (troque em qualquer ambiente real):
APP_DATABASE_URL=postgres://app_role:app_role_local_dev_only@localhost:5432/ai_commerce
